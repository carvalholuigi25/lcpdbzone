{
  "name": "lcpdbzone",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve -c=production --watch=true",
    "startdev": "ng serve -c=development --watch=true",
    "startapi": "json-server --watch src/assets/api/lcpdbzone-api.json --port 3000",
    "startmyapi2": "node --watch server.js",
    "startmyapi2w": "npx nodemon server.js",
    "startmyapi": "C:\\Users\\luisc\\Documents\\projects\\lcpapi\\lcpapi.library\\Scripts\\batch\\startapi.bat",
    "startapis": "concurrently 'npm:startmyapi' 'npm:startmyapi2w'",
    "startall": "concurrently 'npm:startmyapi' 'npm:startmyapi2w' 'npm:start'",
    "startalld": "concurrently 'npm:startmyapi' 'npm:startmyapi2w' 'npm:startdev'",
    "starttestall": "concurrently 'npm:startmyapi' 'npm:test'",
    "starttestcovall": "concurrently 'npm:startmyapi' 'npm:testcoverage'",
    "tsstart": "node -r tsconfig-paths/register dist/index.js",
    "cleancache": "npm cache clean --force",
    "verifycache": "npm cache verify --force",
    "delnmodules": "rmdir /s /q node_modules",
    "delpacklock": "del /f /q package-lock.json",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "testcoverage": "ng test --coverage",
    "serve:ssr:lcpdbzone": "node dist/lcpdbzone/server/server.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "type": "module",
  "packageManager": "npm@11.11.1",
  "dependencies": {
    "@angular/common": "^21.2.4",
    "@angular/compiler": "^21.2.4",
    "@angular/core": "^21.2.4",
    "@angular/forms": "^21.2.4",
    "@angular/platform-browser": "^21.2.4",
    "@angular/platform-server": "^21.2.4",
    "@angular/router": "^21.2.4",
    "@angular/ssr": "^21.2.2",
    "@ng-bootstrap/ng-bootstrap": "^20.0.0",
    "@popperjs/core": "^2.11.8",
    "@sendgrid/mail": "^8.1.6",
    "animate.css": "^4.1.1",
    "axios": "^1.13.6",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "figlet": "^1.11.0",
    "mailgun.js": "^12.7.1",
    "mathjs": "^15.1.1",
    "moment-timezone": "^0.6.0",
    "node-localstorage": "^3.0.5",
    "openai": "^6.31.0",
    "rxjs": "~7.8.2",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.4",
    "@types/bootstrap": "^5.2.10",
    "@types/express": "^5.0.6",
    "@types/jasmine": "^6.0.0",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/video.js": "^7.3.58",
    "@vitest/browser-webdriverio": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "dotenv": "^17.3.1",
    "esbuild": "^0.27.4",
    "jasmine-core": "^6.1.0",
    "jsdom": "^29.0.0",
    "module-alias": "^2.3.4",
    "nodemailer": "^8.0.3",
    "nodemon": "^3.1.14",
    "os": "^0.1.2",
    "path": "^0.12.7",
    "typescript": "~5.9.3",
    "video.js": "^8.23.7",
    "vitest": "^4.1.0"
  },
  "browser": {
    "fs": false
  }
}
