{
  "name": "lcpdbzone",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve -c=production",
    "startdev": "ng serve -c=development",
    "startapi": "json-server --watch src/assets/api/lcpdbzone-api.json --port 3000",
    "startmyapi": "C:\\Users\\luisc\\Documents\\projects\\lcpapi\\lcpapi.library\\Scripts\\batch\\startapi.bat",
    "startall": "concurrently \"npm run startmyapi\" \"npm run start\"",
    "startalld": "concurrently \"npm run startmyapi\" \"npm run startdev\"",
    "tsstart": "node -r tsconfig-paths/register dist/index.js",
    "cleancache": "npm cache clean --force",
    "verifycache": "npm cache verify --force",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "testcoverage": "ng test --coverage",
    "serve:ssr:lcpdbzone": "node dist/lcpdbzone/server/server.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.4",
  "dependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-server": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/ssr": "^21.0.2",
    "@ng-bootstrap/ng-bootstrap": "^20.0.0",
    "@popperjs/core": "^2.11.8",
    "animate.css": "^4.1.1",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "concurrently": "^9.2.1",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.2",
    "@angular/cli": "^21.0.2",
    "@angular/compiler-cli": "^21.0.0",
    "@types/bootstrap": "^5.2.10",
    "@types/express": "^5.0.1",
    "@types/jasmine": "^6.0.0",
    "@types/node": "^20.17.19",
    "@types/video.js": "^7.3.58",
    "@vitest/browser-webdriverio": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "jasmine-core": "^6.0.1",
    "jsdom": "^27.1.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "module-alias": "^2.3.3",
    "typescript": "~5.9.2",
    "video.js": "^8.23.4",
    "vitest": "^4.0.8"
  }
}
