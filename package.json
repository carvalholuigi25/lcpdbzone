{
  "name": "lcpdbzone",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve -c=production",
    "startdev": "ng serve -c=development",
    "startapi": "json-server --watch src/assets/api/lcpdbzone-api.json --port 3000",
    "startmyapi2": "node --watch server.js",
    "startmyapi": "C:\\Users\\luisc\\Documents\\projects\\lcpapi\\lcpapi.library\\Scripts\\batch\\startapi.bat",
    "startapis": "concurrently 'npm:startmyapi' 'npm:startmyapi2'",
    "startall": "concurrently 'npm:startmyapi' 'npm:startmyapi2' 'npm:start'",
    "startalld": "concurrently 'npm:startmyapi' 'npm:startmyapi2' 'npm:startdev'",
    "starttestall": "concurrently 'npm:startmyapi' 'npm:test'",
    "starttestcovall": "concurrently 'npm:startmyapi' 'npm:testcoverage'",
    "tsstart": "node -r tsconfig-paths/register dist/index.js",
    "cleancache": "npm cache clean --force",
    "verifycache": "npm cache verify --force",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "testcoverage": "ng test --coverage",
    "serve:ssr:lcpdbzone": "node dist/lcpdbzone/server/server.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "type": "module",
  "packageManager": "npm@11.10.1",
  "dependencies": {
    "@angular/common": "^21.1.5",
    "@angular/compiler": "^21.1.5",
    "@angular/core": "^21.1.5",
    "@angular/forms": "^21.1.5",
    "@angular/platform-browser": "^21.1.5",
    "@angular/platform-server": "^21.1.5",
    "@angular/router": "^21.1.5",
    "@angular/ssr": "^21.1.4",
    "@ng-bootstrap/ng-bootstrap": "^20.0.0",
    "@popperjs/core": "^2.11.8",
    "animate.css": "^4.1.1",
    "axios": "^1.13.6",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "node-localstorage": "^3.0.5",
    "openai": "^6.22.0",
    "rxjs": "~7.8.2",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.5",
    "@types/bootstrap": "^5.2.10",
    "@types/express": "^5.0.6",
    "@types/jasmine": "^6.0.0",
    "@types/node": "^25.3.0",
    "@types/video.js": "^7.3.58",
    "@vitest/browser-webdriverio": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^17.3.1",
    "jasmine-core": "^6.0.1",
    "jsdom": "^28.1.0",
    "module-alias": "^2.3.4",
    "typescript": "~5.9.3",
    "video.js": "^8.23.7",
    "vitest": "^4.0.18"
  }
}
